# PostgreSQL connection (point this at your local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unesco_whc

# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# JWT secrets — change these in production
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Bootstrap admin (created when you run the seed)
ADMIN_EMAIL=admin@whc.org
ADMIN_PASSWORD=Admin@12345
